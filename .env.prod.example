# Vouchq self-hosted production config (MA3-96).
#
# Copy to `.env`, fill in the REQUIRED values, then keep it private:
#   cp .env.prod.example .env && chmod 600 .env
# `.env` is git-ignored. Never commit real secrets.
#
#   docker compose -f compose.prod.yaml --env-file .env up -d --build
#   (podman compose works the same — same file, both runtimes)

# ── Database ─────────────────────────────────────────────────────────────
VOUCHQ_DB_NAME=vouchq
VOUCHQ_DB_USER=vouchq
# REQUIRED. Use a long random value:  openssl rand -base64 24
VOUCHQ_DB_PASSWORD=

# ── Credential encryption key (REQUIRED) ─────────────────────────────────
# AES key (base64 of 32 bytes) used to encrypt source tokens at rest (MA3-89).
# Generate once and keep it stable — rotating it makes existing stored
# credentials undecryptable.  Generate:  openssl rand -base64 32
VOUCHQ_CREDENTIALS_KEY=

# ── First-boot admin (REQUIRED) ──────────────────────────────────────────
# Seeds a single ADMIN only while the user table is empty. After first login,
# change the password from the console (Settings → Members). Subsequent boots
# ignore these.
VOUCHQ_ADMIN_EMAIL=admin@your-company.example
VOUCHQ_ADMIN_PASSWORD=

# ── App / console ────────────────────────────────────────────────────────
# Image tag to run for both app + console (set when deploying a pinned release).
VOUCHQ_VERSION=latest
# Backend host port — loopback only, for ops/health (the console fronts traffic).
VOUCHQ_PORT=8080
# Console host port — this is the front door. Put your TLS reverse proxy here.
VOUCHQ_CONSOLE_PORT=3000

# ── Background re-scan (rug-pull detection) ──────────────────────────────
VOUCHQ_RESCAN_ENABLED=true
VOUCHQ_RESCAN_INTERVAL_MS=3600000
VOUCHQ_RESCAN_INITIAL_DELAY_MS=60000

# ── Notifications (OFF by default — 기획서 §7) ────────────────────────────
# Enable only the channels you want; each makes outbound calls when enabled.
# VOUCHQ_NOTIFY_WEBHOOK_ENABLED=true
# VOUCHQ_NOTIFY_WEBHOOK_URL=https://hooks.internal.example/vouchq
# VOUCHQ_NOTIFY_SLACK_ENABLED=true
# VOUCHQ_NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# VOUCHQ_NOTIFY_EMAIL_ENABLED=true
# VOUCHQ_NOTIFY_EMAIL_FROM=vouchq@your-company.example
# VOUCHQ_NOTIFY_EMAIL_TO=secops@your-company.example

# ── Policy engine (local-only; on by default) ────────────────────────────
# VOUCHQ_POLICY_ENABLED=true
